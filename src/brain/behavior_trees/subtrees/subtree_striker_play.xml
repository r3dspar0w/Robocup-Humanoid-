<root BTCPP_format="4" >
   <include path="./subtree_cam_find_and_track_ball.xml" />
   <include path="./subtree_find_ball.xml" />
   <include path="./subtree_locate.xml" />
   <BehaviorTree ID="StrikerPlay">
      <ReactiveSequence>

         <!-- Figure out where robot is -->
         <!-- mode="trust_direction" -> Trust compass and less reliance on visual landmarks-->
         <SelfLocate mode="trust_direction" />

         <!-- Keep updating my position unless I am actively searching the ball -->
         <SubTree ID="Locate" _autoremap="true" _while="decision!='find'" />

         <!-- Waiting for opponents to start the game -->
         <ReactiveSequence _while="wait_for_opponent_kickoff" name="wait for opponent kickoff">

            <!-- Look at ball and stay still -->
            <SubTree ID="CamFindAndTrackBall" _autoremap="true" />
            <SetVelocity />
         </ReactiveSequence>

         <!-- Normal Match Logic -->
         <ReactiveSequence _while="!wait_for_opponent_kickoff" name="our kickoff or opponent already kicked off">

            <!-- If Ball is outside field -->
            <Sequence _while="ball_out">
               <!-- 
               What Robot Does
                  1. Look For ball
                  2. Move back into field
                  3. Recalculate Position
               To Prevent: Illegal positioning, or robot wandering out
               -->
               <SubTree ID="CamFindAndTrackBall" _autoremap="true" />
               <GoBackInField />
               <SubTree ID="Locate" _autoremap="true" _while="decision!='find'" />
            </Sequence>

            <!-- Main Gameplay -->
            <ReactiveSequence _while="!ball_out">
               <ReactiveSequence >
                  <!-- See Ball -->
                  <SubTree ID="CamFindAndTrackBall" _autoremap="true" />

                  <!-- Calculate Kick Direction (robot is planning how to kick) -->
                  <CalcKickDir />
                  <Sequence>
                     <ReactiveSequence>

                        <!-- Decision Making Core (MOST IMPORTANT) -->
                        <!-- 
                           It Outputs one of the decisions:
                           - Find
                           - Assist
                           - Chase
                           - Adjust
                           - Kick
                           - Cross
                        -->
                        <StrikerDecide decision_out="{decision}" decision_in="{decision}" chase_threshold="0.85"
                                       straight_kick_yaw_tolerance="0.22"
                                       straight_kick_y_tolerance="0.18"
                                       straight_kick_goal_tolerance="0.35"
                                       straight_kick_goalpost_margin="0.15"
                                       straight_kick_obstacle_dist="1.3"
                                       straight_kick_max_range="1.45" />
                        <!-- Start Searching for ball -->
                        <SubTree ID="FindBall" _while="decision=='find'" _autoremap="true" />
                     </ReactiveSequence>

                        <!-- 
                        ASSIST
                           Move Slowly and Carefully to Support
                           Used when positioning for pass
                        -->
                        <Assist _while="decision == 'assist'" vx_limit = "0.2" vy_limit="0.2" />

                        <!-- 
                        CHASE
                           Run Towards the Ball
                           
                           Variable Description:
                              vx_limit -> Forward Speed
                              vy_limit -> Sideways movement
                              vtheta_limit -> Turning Speed
                              dist -> Stopping Distance
                              safe_dist -> Avoid Collisions
                        -->
                        <StrikerChase   _while="decision == 'chase'"  vx_limit="1.0"  vy_limit="0.35"  vtheta_limit="1.2"  dist="0.1" safe_dist="0.65"
                                        open_vx_limit="1.2"
                                        open_vtheta_limit="1.4"
                                        open_robot_near_ball_dist="1.5"
                                        curve_when_behind="true"
                                        curve_lateral_gain="0.8"
                                        curve_lateral_bias="0.12" />

                        <!-- 
                        AUTO VISUAL KICK
                           Uses Camera + AI (vision) to decide how to kick
                           Does not require perfect positioning
                           Faster and more reactive
                           Less Precise but more aggressive

                        RLVision -> Should stand for `Reinforcement Learning`

                        Parameters
                           min_msec_kick -> Minimum Time Spent Kicking (prevents weak kicks)
                           max_max_kick -> Max Time Spent Kicking (prevents robot from being stuck kicking forever)
                           range -> Max Distance where this behavior is allowed (if ball is too far -> it wont use autokick)
                        -->
                        <RLVisionKick _while="decision == 'auto_visual_kick'" min_msec_kick="1500" max_msec_kick="7000" range="6.0"/>

                        <!-- 
                        ADJUST
                           Position myself correctly before kicking
                           
                           This aligns with goal, adjust angle and finetune position

                        -->
                        <Adjust _while="decision =='adjust'" turn_threshold="0.5" range="0.35" vx_limit="0.8" vy_limit="0.7" vtheta_limit="1.5" vtheta_factor="1.5" tangential_speed_far="0.75" tangential_speed_near="0.25" no_turn_threshold="0.18" turn_first_threshold="0.9" />

                        <!-- 
                        KICK
                           Shoot the ball
                           
                           Variable Description:
                              speed_limit -> Kick Strength
                              min_msec_kick -> Duration to kick by
                              msecs_stablize -> Balance Before Kick
                        -->
                        <Kick _while="decision == 'kick'" speed_limit="0.9" min_msec_kick="900" msecs_stablize="1000"
                              prefer_straight="true"
                              straight_yaw_tolerance="0.22"
                              straight_y_tolerance="0.18"
                              straight_goal_tolerance="0.35"
                              straight_goalpost_margin="0.15"
                              straight_obstacle_dist="1.3"
                              straight_speed_limit="1.1"/>

                        <!-- CROSS - Pass Instead of Shoot -->
                        <Kick _while="decision == 'cross'" speed_limit="0.4" min_msec_kick="300"/>
                  </Sequence>
               </ReactiveSequence>
            </ReactiveSequence>
         </ReactiveSequence>
      </ReactiveSequence>
   </BehaviorTree>
</root>
