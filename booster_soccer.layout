        {
          "id": "88345f1f-eb82-43d2-aa71-d610a642f497",
          "name": "Detection",
          "visible": true,
          "code": "@on_message(topic='/booster_soccer/detection',  anti_flicker=True)\ndef draw_bounding_box(msg):\n    for obj in msg.detected_objects:\n        color = \"#FFFFFFFF\"\n        if obj.label == \"XCross\":\n            color = \"#0000FFFF\"\n        elif obj.label == \"LCross\":\n            color = \"#FFFF00FF\"\n        elif obj.label == \"TCross\":\n            color = \"#00FF00FF\"\n        elif obj.label == \"Goalpost\":\n            color = \"#007777FF\"\n        elif obj.label == \"PenaltyPoint\":\n            color = \"#FF7700FF\"\n        draw2d.box(obj.xmin, obj.ymin, obj.xmax, obj.ymax) \\\n            .stroke_color(color) \\\n            .stroke_width(2) \\\n            .label(obj.label)",
          "showLabel": true,
          "status": "success",
          "opacity": 100
        }
      ],
