    "Canvas!44ot63c": {
      "axis": "right",
      "showAxis": false,
      "showGrid": true,
      "customLayers": [
        {
          "id": "c158e0f1-6909-4ccc-a34a-dac6a72ffed4",
          "name": "Field",
          "visible": true,
          "opacity": 100,
          "code": "@on_message(\"/booster_soccer/field_dimensions\")\r\ndef draw_field(msg):\r\n    data = msg.data\r\n    length = data[0]\r\n    width = data[1]\r\n    penalty_dist = data[2]\r\n    goal_width = data[3]\r\n    circle_r = data[4]\r\n    penalty_area_length = data[5]\r\n    penalty_area_width = data[6]\r\n    goal_area_length = data[7]\r\n    goal_area_width = data[8]\r\n\r\n    # Field\r\n    draw2d.box(-length / 2 - 2, -width / 2 - 2, length / 2 + 2, width / 2 + 2).stroke_width(0).fill_color(\"#009900FF\")\r\n    draw2d.line(-length / 2, -width / 2, -length / 2, width / 2).stroke_width(0.08, False)\r\n    draw2d.line(-length / 2, -width / 2, length / 2, -width / 2).stroke_width(0.08, False)    \r\n    draw2d.line(length / 2, width / 2, -length / 2, width / 2).stroke_width(0.08, False)\r\n    draw2d.line(length / 2, width / 2, length / 2, -width / 2).stroke_width(0.08, False)\r\n    draw2d.circle(0, 0, circle_r).stroke_width(0.08, False)\r\n\r\n    # penalty point\r\n    draw2d.line(-length / 2 + penalty_dist - 0.1, 0, -length / 2 + penalty_dist + 0.1, 0)\r\n    draw2d.line(-length / 2 + penalty_dist, -0.1, -length / 2 + penalty_dist, 0.1)\r\n    draw2d.line(length / 2 - penalty_dist - 0.1, 0, length / 2 - penalty_dist + 0.1, 0)\r\n    draw2d.line(length / 2 - penalty_dist, -0.1, length / 2 - penalty_dist, 0.1)\r\n\r\n    # goal area\r\n    draw2d.line(-length / 2, -goal_area_width / 2, -length / 2 + goal_area_length, -goal_area_width / 2)\r\n    draw2d.line(-length / 2, goal_area_width / 2, -length / 2 + goal_area_length, goal_area_width / 2)\r\n    draw2d.line(-length / 2 + goal_area_length, -goal_area_width / 2, -length / 2 + goal_area_length, goal_area_width / 2)\r\n    draw2d.line(length / 2, -goal_area_width / 2, length / 2 - goal_area_length, -goal_area_width / 2)\r\n    draw2d.line(length / 2, goal_area_width / 2, length / 2 - goal_area_length, goal_area_width / 2)\r\n    draw2d.line(length / 2 - goal_area_length, -goal_area_width / 2, length / 2 - goal_area_length, goal_area_width / 2)\r\n\r\n    # penalty area\r\n    draw2d.line(-length / 2, -penalty_area_width / 2, -length / 2 + penalty_area_length, -penalty_area_width / 2)\r\n    draw2d.line(-length / 2, penalty_area_width / 2, -length / 2 + penalty_area_length, penalty_area_width / 2)\r\n    draw2d.line(-length / 2 + penalty_area_length, -penalty_area_width / 2, -length / 2 + penalty_area_length, penalty_area_width / 2)\r\n    draw2d.line(length / 2, -penalty_area_width / 2, length / 2 - penalty_area_length, -penalty_area_width / 2)\r\n    draw2d.line(length / 2, penalty_area_width / 2, length / 2 - penalty_area_length, penalty_area_width / 2)\r\n    draw2d.line(length / 2 - penalty_area_length, -penalty_area_width / 2, length / 2 - penalty_area_length, penalty_area_width / 2)\r\n\r\n    # goal\r\n    draw2d.line(-length / 2, -goal_width / 2, -length / 2 - 0.5, -goal_width / 2)\r\n    draw2d.line(-length / 2, goal_width / 2, -length / 2 - 0.5, goal_width / 2)\r\n    draw2d.line(-length / 2 - 0.5, goal_width / 2, -length / 2 - 0.5, -goal_width / 2)\r\n    draw2d.line(length / 2, -goal_width / 2, length / 2 + 0.5, -goal_width / 2)\r\n    draw2d.line(length / 2, goal_width / 2, length / 2 + 0.5, goal_width / 2)\r\n    draw2d.line(length / 2 + 0.5, goal_width / 2, length / 2 + 0.5, -goal_width / 2)",
          "showLabel": true,
          "status": "success"
        },
        {
          "id": "c8329279-8401-47c4-a6f3-84460ca8838d",
          "name": "Robot",
          "visible": true,
          "opacity": 100,
          "code": "import math\r\n@on_message(\"/booster_soccer/robot_pose\")\r\ndef draw_robot(msg):\r\n    x = msg.x\r\n    y = msg.y\r\n    theta = msg.theta\r\n    print(f'x={x}y={y}t={theta}')\r\n    draw2d.circle(x, y, 0.3).stroke_color(\"#FF0000FF\").stroke_width(4)\r\n    draw2d.line(x,y, x + math.cos(theta) * 0.6, y + math.sin(theta) * 0.6).stroke_color(\"#FF0000FF\").stroke_width(4)\r\n",
          "showLabel": true,
          "status": "success"
        },
        {
          "id": "45126e07-8b6a-4258-81e7-53dd4fd0d0a3",
          "name": "Ball",
          "visible": true,
          "opacity": 100,
          "code": "\r\n@on_message(\"/booster_soccer/ball_position\")\r\ndef draw_ball(msg):\r\n    x = msg.x\r\n    y = msg.y\r\n    draw2d.circle(x, y, 0.1).stroke_color(\"#FFFFFFFF\").stroke_width(4)\r\n    draw2d.line(x - 0.5, y, x + 0.5, y).stroke_width(4)\r\n    draw2d.line(x, y - 0.5, x, y + 0.5).stroke_width(4)",
          "showLabel": true,
          "status": "success"
        }
      ],
